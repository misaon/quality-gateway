{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "semi": false,
  "ignorePatterns": [
    "**/dist/**",
    "**/coverage/**",
    "**/node_modules/**",
    "**/.stryker-tmp/**",
    "**/*.tsbuildinfo",
    "pnpm-lock.yaml",
    "**/CHANGELOG.md",
    "CODE_OF_CONDUCT.md"
  ]
}
