{
  "name": "quality-gateway",
  "version": "0.0.0",
  "private": true,
  "description": "Modern PNPM monorepo of composable quality configs (ESLint & more) + an installable CLI.",
  "license": "MIT",
  "author": "Ondřej Misák <email@ondrejmisak.cz> (https://ondrejmisak.cz/)",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" run build",
    "dev": "pnpm --filter \"./packages/*\" --parallel run dev",
    "typecheck": "pnpm --filter \"./packages/*\" run typecheck && tsc -p tsconfig.json",
    "clean": "pnpm --filter \"./packages/*\" run clean",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "spell": "cspell --no-progress \"**/*.{ts,js,mjs,json,json5,md,yml,yaml}\"",
    "lint:md": "markdownlint-cli2",
    "knip": "knip",
    "lint:publish": "pnpm --filter \"./packages/*\" run lint:publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "mutation": "stryker run",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@misaon/quality-gateway": "workspace:*",
    "@stryker-mutator/core": "catalog:",
    "@stryker-mutator/vitest-runner": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cspell": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "lefthook": "catalog:",
    "markdownlint-cli2": "catalog:",
    "oxfmt": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.9.0"
}
