{
  "name": "quality-gateway",
  "version": "0.0.0",
  "private": true,
  "description": "Modern PNPM monorepo of composable quality configs (ESLint & more) + an installable CLI.",
  "type": "module",
  "author": "Ondřej Misák <email@ondrejmisak.cz> (https://ondrejmisak.cz/)",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" run build",
    "dev": "pnpm --filter \"./packages/*\" --parallel run dev",
    "typecheck": "pnpm --filter \"./packages/*\" run typecheck",
    "clean": "pnpm --filter \"./packages/*\" run clean",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@misaon/eslint-config-common": "workspace:*",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "knip": "catalog:",
    "lefthook": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
