{
  "name": "@misaon/eslint-config-next",
  "version": "0.2.0",
  "description": "ESLint flat config for Next.js. Extends @misaon/eslint-config-react with @next/eslint-plugin-next.",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslintconfig",
    "flat-config",
    "next",
    "nextjs"
  ],
  "homepage": "https://github.com/misaon/quality-gateway/tree/main/packages/eslint-config-next#readme",
  "bugs": {
    "url": "https://github.com/misaon/quality-gateway/issues"
  },
  "license": "MIT",
  "author": "Ondřej Misák <email@ondrejmisak.cz> (https://ondrejmisak.cz/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/misaon/quality-gateway.git",
    "directory": "packages/eslint-config-next"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint:publish": "publint && attw --pack . --ignore-rules cjs-resolves-to-esm"
  },
  "dependencies": {
    "@misaon/eslint-config-react": "workspace:*",
    "@next/eslint-plugin-next": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "typescript": ">=5"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
