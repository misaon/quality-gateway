{
  "name": "@misaon/quality-gateway",
  "version": "0.1.0",
  "description": "CLI that detects your stack and wires the matching @misaon quality configs (ESLint & more) into your project.",
  "keywords": [
    "cli",
    "eslint",
    "linting",
    "monorepo",
    "quality",
    "scaffold"
  ],
  "homepage": "https://github.com/misaon/quality-gateway/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/misaon/quality-gateway/issues"
  },
  "license": "MIT",
  "author": "Ondřej Misák <email@ondrejmisak.cz> (https://ondrejmisak.cz/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/misaon/quality-gateway.git",
    "directory": "packages/cli"
  },
  "bin": {
    "qg": "./dist/index.js",
    "quality-gateway": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./eslint": {
      "types": "./dist/eslint.d.ts",
      "default": "./dist/eslint.js"
    },
    "./oxfmt": {
      "types": "./dist/oxfmt.d.ts",
      "default": "./dist/oxfmt.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint:publish": "publint"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@misaon/eslint-config-common": "workspace:*",
    "c12": "catalog:",
    "citty": "catalog:",
    "cli-table3": "catalog:",
    "cli-truncate": "catalog:",
    "confbox": "catalog:",
    "consola": "catalog:",
    "listr2": "catalog:",
    "nano-spawn": "catalog:",
    "nypm": "catalog:",
    "pkg-types": "catalog:",
    "string-width": "catalog:",
    "tinyglobby": "catalog:"
  },
  "devDependencies": {
    "@misaon/eslint-config-next": "workspace:*",
    "@misaon/eslint-config-node": "workspace:*",
    "@misaon/eslint-config-react": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@misaon/eslint-config-next": "workspace:*",
    "@misaon/eslint-config-node": "workspace:*",
    "@misaon/eslint-config-react": "workspace:*",
    "eslint": ">=10",
    "oxfmt": ">=0.56",
    "typescript": ">=5"
  },
  "peerDependenciesMeta": {
    "@misaon/eslint-config-next": {
      "optional": true
    },
    "@misaon/eslint-config-node": {
      "optional": true
    },
    "@misaon/eslint-config-react": {
      "optional": true
    },
    "oxfmt": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
